@model UserClient.Models.UserViewModel

@{
    ViewData["Title"] = "Supprimer un utilisateur";
}

<h2>Confirmer la suppression</h2>

<div class="alert alert-danger">
    Êtes-vous sûr de vouloir supprimer cet utilisateur ?
</div>

<dl class="row">
    <dt class="col-sm-3">Nom</dt>
    <dd class="col-sm-9">@TempData["UserNom"]</dd>

    <dt class="col-sm-3">Prénom</dt>
    <dd class="col-sm-9">@TempData["UserPrenom"]</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@TempData["UserEmail"]</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>