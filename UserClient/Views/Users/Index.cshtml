@model List<UserClient.Models.UserViewModel>

@{
    ViewData["Title"] = "Liste des utilisateurs";
}

<h2>Liste des utilisateurs</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ Nouvel utilisateur</a>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Rôle</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Nom</td>
                <td>@user.Prenom</td>
                <td>@user.Email</td>
                <td>@user.Telephone</td>
                <td>@user.Role</td>
                <td>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-info btn-sm">Détails</a>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-warning btn-sm">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>