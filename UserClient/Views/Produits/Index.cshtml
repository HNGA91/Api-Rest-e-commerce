@model List<UserClient.Models.ProduitViewModel>

@{
    ViewData["Title"] = "Liste des produits";
}

<h2>Liste des produits</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ Nouveau produit</a>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Nom</th>
            <th>Prix</th>
            <th>Stock</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var produit in Model)
        {
            <tr>
                <td>@produit.Nom</td>
                <td>@produit.Prix.ToString("C")</td>
                <td>@produit.Stock</td>
                <td>
                    <a asp-action="Details" asp-route-id="@produit.Id" class="btn btn-info btn-sm">Détails</a>
                    <a asp-action="Edit" asp-route-id="@produit.Id" class="btn btn-warning btn-sm">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@produit.Id" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>