@model UserClient.Models.ProduitViewModel

@{
    ViewData["Title"] = "Détails produit";
}

<h2>Détails du produit</h2>

<dl class="row">
    <dt class="col-sm-3">Nom</dt>
    <dd class="col-sm-9">@Model.Nom</dd>

    <dt class="col-sm-3">Prix</dt>
    <dd class="col-sm-9">@Model.Prix.ToString("C")</dd>

    <dt class="col-sm-3">Stock</dt>
    <dd class="col-sm-9">@Model.Stock</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Modifier</a>
<a asp-action="Index" class="btn btn-secondary">Retour</a>