@model UserClient.Models.ProduitViewModel

@{
    ViewData["Title"] = "Supprimer un produit";
}

<h2>Confirmer la suppression</h2>

<div class="alert alert-danger">
    Êtes-vous sûr de vouloir supprimer ce produit ?
</div>

<dl class="row">
    <dt class="col-sm-3">Nom</dt>
    <dd class="col-sm-9">@TempData["ProduitNom"]</dd>

    <dt class="col-sm-3">Prix</dt>
    <dd class="col-sm-9">@TempData["ProduitPrix"]</dd>

    <dt class="col-sm-3">Stock</dt>
    <dd class="col-sm-9">@TempData["ProduitStock"]</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>